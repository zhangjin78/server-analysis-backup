  CFLAGSB += -pg
endif

CFLAGS=       $(CFLAGSB)   
CFLAGSTOFSIM= $(CFLAGSB) 
CFLAGSn=      $(CFLAGSB)
CFLAGSDAQ=    $(CFLAGSB) 

FFLAGS= -fPIC -fno-automatic
FFLAGSn=      -fno-automatic

ifeq ($(shell echo "$$(( $(GCC_VER_MAJOR) > 9 ))"), 1)
