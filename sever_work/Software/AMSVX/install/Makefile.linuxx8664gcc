    CFLAGSn      += -g -fno-omit-frame-pointer 
    CFLAGSDAQ    += -g -fno-omit-frame-pointer 
    FFLAGS       += -g -fno-omit-frame-pointer 
    FFLAGSn      += -g -fno-omit-frame-pointer 
endif
endif
