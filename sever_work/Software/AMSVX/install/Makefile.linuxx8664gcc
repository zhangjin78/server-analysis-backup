    CFLAGSn      += -O2
    CFLAGSDAQ    += -O2
    FFLAGS       += -O3
    FFLAGSn      += -O2
ifdef RELWITHDEBUGFLAG
    CFLAGS       += -g -fno-omit-frame-pointer 
