########################################################################
#Compilers
########################################################################

#If using Geant, we now have to check CC_env since origin environment is removed
ifneq "$(CC_env)" ""
  CC  = $(CC_env)
else
ifneq "$(origin CC)" "environment" 
  CC  = gcc  
endif
endif
ifneq "$(CXX_env)" ""
  CXX = $(CXX_env)
else
ifneq "$(origin CXX)" "environment" 
  CXX = g++ 
endif
endif
ifdef VERGCC 
ifneq "$(origin FF)" "environment" 
  FF  = gfortran  
endif
  FORTRAN_LIBS=-lgfortran  -lc 
ifeq ($(GCC_VER_MAJOR),4) 
ifeq ($(GCC_VER_MIDDLE),9)
  FORTRAN_LIBS+= -lquadmath 
endif
endif
ifeq ($(shell echo "$$(( $(GCC_VER_MAJOR) > 4 ))"), 1)
  FORTRAN_LIBS+= -lquadmath
  WABIFLAG = -Wabi-tag
endif


else  
ifneq "$(origin FF)" "environment" 
  FF  = g77  
endif
  FORTRAN_LIBS=
endif
  FFOLD=$(FF)
ifneq "$(origin LD)" "environment" 
  LD  = g++ 
endif
  FORTRAN2_LIBS=

ifndef IS_CORBA64
  ORBIT2DIR=$(AMSDEPLIB)/Orbit2
  IDL=$(ORBIT2DIR)/bin/orbit-idl-2
  IDLCPP=$(ORBIT2DIR)/bin/orbit-idl-2 -l cpp --backenddir=$(ORBIT2DIR)/lib/orbit-2.0/idl-backends
else
  ifndef AMSDYNSERVER
    ORBIT2DIR=$(AMSDEPLIB)/ORBit2-2.14.17.gcc64-41
  else
    ORBIT2DIR=$(AMSDEPLIB)/ORBit2-2.14.19.gcc64-48
  endif
  IDL=/usr/bin/orbit-idl-2
  IDLCPP=/usr/bin/orbit-idl-2 -l cpp --backenddir=$(ORBIT2DIR)/lib64/idl-compiler
  DEFINES+= -D_IS_CORBA64_
endif


