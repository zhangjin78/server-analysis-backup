# Try to find INTELLIB
########################################################################

ifeq ("$(INTELLIB)", "")
  ifneq ("$(wildcard $(INTELDIR)/$(INTELVER)/compiler/lib/intel64/libimf*)","")
    INTELLIB = $(INTELDIR)/$(INTELVER)/compiler/lib/intel64
  else ifneq ("$(wildcard $(INTELDIR)/$(INTELVER)/linux/compiler/lib/intel64/libimf*)","")
    INTELLIB = $(INTELDIR)/$(INTELVER)/linux/compiler/lib/intel64
  else ifneq ("$(wildcard $(INTELDIR)/$(INTELVER)/lib/intel64/libimf*)","")
    INTELLIB = $(INTELDIR)/$(INTELVER)/lib/intel64
  else ifneq ("$(wildcard $(INTELDIR)/$(INTELVER)/lib/libimf*)","")
    INTELLIB = $(INTELDIR)/$(INTELVER)/lib
  endif
endif

ifeq ("$(INTELLIB)", "")
