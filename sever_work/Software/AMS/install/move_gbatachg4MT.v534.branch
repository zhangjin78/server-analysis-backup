ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v5.02.0.$BUILDNO.g4
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v5.02.1.$BUILDNO.g4.64.alma9
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v5.02.0.$BUILDNO.g4.64.alma9
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v5.02.1.$BUILDNO.g4.alma9
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v5.02.0.$BUILDNO.g4.alma9

ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.knl $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.1.$BUILDNO.g4.64.knl
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.knl $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.0.$BUILDNO.g4.64.knl
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.knl $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.1.$BUILDNO.g4.knl
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.knl $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.0.$BUILDNO.g4.knl
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.1.$BUILDNO.g4.64
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.0.$BUILDNO.g4.64
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.1.$BUILDNO.g4
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.0.$BUILDNO.g4
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.1.$BUILDNO.g4.64.alma9
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.0.$BUILDNO.g4.64.alma9
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.1.$BUILDNO.g4.alma9
ln -sf gbatch-orbit.exe.v5.00.0.$BUILDNO.g4.64.alma9 $AMSDataDir/DataManagement/exe/linux/gbatch-orbit.exe.v6.00.0.$BUILDNO.g4.alma9

