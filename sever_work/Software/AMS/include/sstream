#ifndef __sstream_ams__
#define __sstream_ams__

/////////////////////////////////////////////////////////////////////////////////////////
// Wrapper file to fix sstream include in case 'private' keyword is defined
//
// Problem: 'sstream' header included with GCC 5.1.0+ does not build when the
// 'private' keyword is defined.
//
// See https://gcc.gnu.org/bugzilla/show_bug.cgi?id=65899 for details
//
// This is problematic in particular when dictionaries autogenerated by rootcint
// are compiled - where we have no control over the define. Fix this by
// undefining private temporarily and then including the system's sstream

#ifdef private

// temporarily undefine the private keyword
#undef private
#include_next <sstream>
#define private public

#else

// just include the system header
#include_next <sstream>

#endif

#endif
